generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}




model UserProfile {
  id           String    @id @default(uuid())
  name         String
  email        String?    @unique
  age          Int?
  gender       String?   // e.g. "Male", "Female", "Transgender", ""
  state        String?
  caste        String?   // e.g. "General", "OBC", "SC", "ST", ""
  annualIncome Float?
  occupation   String?
  disability   Boolean?  @default(false)
  avatarUrl    String?   @default("")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  // Data Relations
  savedSchemes SavedScheme[]
  applications TrackedApplication[]
  documents    UserDocument[]
  feedbacks    SchemeFeedback[]
  loginDetails UserLogin?           // One-to-one relation with credentials
}

model SavedScheme {
  id       String      @id @default(uuid())
  userId   String
  schemeId String
  savedAt  DateTime    @default(now())

  // Relations
  user     UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, schemeId])
}

model TrackedApplication {
  id             String      @id @default(uuid())
  userId         String
  schemeId       String
  status         String      @default("Applied") // 'Draft', 'Applied', 'Under Review', 'Approved', 'Rejected'
  applicationRef String      @unique
  remarks        String?
  appliedAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  // Relations
  user           UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, schemeId])
}

model UserDocument {
  id         String      @id @default(uuid())
  userId     String
  docType    String      // e.g. 'Aadhaar', 'Pan Card', 'Income Certificate', 'Caste Certificate'
  fileName   String
  fileSize   String
  uploadedAt DateTime    @default(now())
  docUrl     String?     @default("#")

  // Relations
  user       UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SchemeFeedback {
  id        String      @id @default(uuid())
  userId    String
  schemeId  String
  rating    Int         // 1 to 5
  comments  String?
  createdAt DateTime    @default(now())

  // Relations
  user      UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, schemeId])
}

model UserLogin {
  id           String   @id @default(uuid())
  userId       String   @unique  // Ensures 1-to-1 relationship with profile
  username     String   @unique
  emailId      String?   @unique
  mobileNumber String   @unique
  password     String   // Hashed passwords should be stored here
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  user         UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AdminLogin {
  id           String   @id @default(uuid())
  username     String   @unique
  emailId      String?   @unique
  mobileNumber String   @unique
  password     String   // Hashed passwords should be stored here
  role         String   @default("ADMIN") // e.g., "SUPER_ADMIN", "MODERATOR"
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
} 
model ContactMessage {
  id          String   @id @default(uuid())
  name        String
  contactInfo String
  subject     String?
  message     String
  createdAt   DateTime @default(now())

  @@map("contact_messages")
}